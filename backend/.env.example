# Kremlin Backend Environment Variables Template
PORT=5000

# PostgreSQL Database Connection (Unified URL or discrete parts)
# If DATABASE_URL is provided, it will be used. Otherwise, DB_USER/etc will be used.
DATABASE_URL=postgresql://postgres:1234@localhost:5432/kremlin_studios

# Alternative database settings:
DB_USER=postgres
DB_PASSWORD=1234
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kremlin_studios

# Security
JWT_SECRET=kremlin_studios_super_secret_ai_9988
ADMIN_REGISTRATION_TOKEN=kremlin_admin_token_2026

# AI Chatbot Concierge Config
OPENAI_API_KEY=your_openai_api_key_here
